# Copy this file to .env and fill in your actual keys
# Get GNews key at: https://gnews.io/
# Get Guardian key at: https://open-platform.theguardian.com/access/
# Get Groq key (free) at: https://console.groq.com/
# Get Pexels key (free) at: https://www.pexels.com/api/
# Gmail App Password (free) at: https://myaccount.google.com/apppasswords

GNEWS_API_KEY=your_gnews_key_here
GUARDIAN_API_KEY=your_guardian_key_here
GROQ_API_KEY=your_groq_key_here
PEXELS_API_KEY=your_pexels_key_here
GMAIL_ADDRESS=your_gmail_address_here
GMAIL_APP_PASSWORD=your_16_char_app_password_here
NOTIFY_TO_EMAIL=your_gmail_address_here
